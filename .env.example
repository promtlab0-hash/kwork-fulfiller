# Бэкенд генерации. Скопируйте в `.env` и раскомментируйте нужный блок.
# Движок провайдеро-независимый: claude (CLI) или любой OpenAI-совместимый endpoint.
# Приоритет: флаги CLI (--backend/--model/--base-url) > переменные окружения > .env.

# --- (1) Claude — по умолчанию, ничего настраивать не надо ---------------------
# Использует локально залогиненный `claude` CLI (или CLAUDE_CODE_OAUTH_TOKEN в CI).
# LLM_BACKEND=claude

# --- (2) OpenRouter + Qwen (облако, бесплатный тир) ----------------------------
# Ключ: https://openrouter.ai/keys (бесплатно). Набор free-моделей меняется —
# актуальные смотрите на https://openrouter.ai/models?q=qwen (помечены ":free").
# LLM_BACKEND=openai
# LLM_BASE_URL=https://openrouter.ai/api/v1
# LLM_MODEL=qwen/qwen-2.5-72b-instruct:free
# LLM_API_KEY=sk-or-...

# --- (3) Ollama + Qwen (локально, бесплатно, безлимитно, оффлайн) --------------
# Установка: https://ollama.com → `ollama pull qwen2.5` (7b). Для качества — 14b/32b.
# Если Ollama на Windows, а скрипт в WSL и localhost не виден — подставьте IP хоста.
# LLM_BACKEND=openai
# LLM_BASE_URL=http://localhost:11434/v1
# LLM_MODEL=qwen2.5:7b-instruct
# LLM_API_KEY=ollama
